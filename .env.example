# ThinkPay secrets — copy to .env and fill. NEVER commit .env (it is gitignored).

# BTL Runtime inference key (from the hackathon dashboard, "inference" scope)
GATEWAY_API_KEY=

# Buyer wallet private key (0x-prefixed). Funded with Base Sepolia test USDC.
# This is the ONLY secret the payment module reads. Never goes into any LLM prompt.
EVM_PRIVATE_KEY=

# Address that receives test USDC on the mock provider (your own wallet address is fine).
SERVER_PAY_TO_ADDRESS=

# x402 testnet facilitator (no signup). Alt seen in the 2.17.0 README: https://facilitator.x402.org
X402_FACILITATOR_URL=https://x402.org/facilitator
