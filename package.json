{
  "name": "thinkpay",
  "private": true,
  "version": "0.0.0",
  "description": "ThinkPay — a spending control plane for AI agents (BTL Runtime + x402)",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "mock": "pnpm --filter mock-provider dev",
    "web": "pnpm --filter web dev",
    "smoke:btl": "pnpm --filter agent smoke:btl",
    "smoke:x402": "pnpm --filter agent smoke:x402",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx packages/shared/src/db/seed.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.23.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7"
    }
  }
}
