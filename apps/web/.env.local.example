# ThinkPay dashboard config — copy to .env.local (gitignored) to override defaults.
# These are PUBLIC (NEXT_PUBLIC_*) build-time values — no secrets here.

# Where the agent API + SSE server lives (Phase 4 backend). Default matches `pnpm agent`.
NEXT_PUBLIC_AGENT_URL=http://localhost:3001

# Boot mode: "1" (default) starts in SIM (scripted demo, no backend needed);
# set to "0" to boot straight into LIVE (talks to NEXT_PUBLIC_AGENT_URL).
# You can also flip sim/live at runtime with the toggle in RunControls.
NEXT_PUBLIC_SIM_MODE=1
